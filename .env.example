# Copy to ".env" locally (never commit .env).

# --- 默认：火山引擎方舟 OpenAI 兼容（chat.completions）---
# 文档：https://www.volcengine.com/docs/82379/1399008
ARK_API_KEY=

OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MODEL_NAME=doubao-seed-2-0-lite-260215
# 聊天里上传图片走多模态时，MODEL_NAME 须为支持 vision 的推理接入点；单图约 4MB 内、每轮最多 6 张（见 chat_attachments）

# 本轮默认推理档位（minimal/low/medium/high）；web_app 未传 reasoning_effort 时由指挥官规则或路由器决定，规则未命中则用此值
# REASONING_EFFORT_DEFAULT=medium

# 设为 llm 时先做一次轻量模型路由（该次调用固定 minimal）；失败则回退规则。仅增加一次额外请求
# ARIA_REASONING_ROUTER=

# 为 1 时：对非 JSON 类 Agent（如子任务执行、TAOR、闲聊）通过 SSE 向聊天窗推送模型分片，需页面已连接 /api/workflow_stream
# ARIA_LLM_STREAM=1

# 强时效任务(temporal_risk=high)：方法论相似度落在 [本值, 0.7) 时沿用已匹配流程、跳过整段 learn_from_external 以省 Token
# ARIA_TEMPORAL_METHOD_MATCH_FLOOR=0.45

# 方舟：档位映射到请求体 reasoning_effort。百炼：minimal 关闭 enable_thinking，low/medium/high 仍受 ENABLE_THINKING 与多模态限制
# 方舟一般无需百炼的思考参数；若遇兼容问题可显式关闭
# ENABLE_THINKING=false

# 是否在执行 browser_* / desktop_* 等动作后自动全屏截图（与网页端勾选「动作后截屏」二选一即可，不必同时开）
# ARIA_ACTION_SCREENSHOT=1

# ReAct 模式：单会话内 Thought→Action→Observation 最大迭代步数（防死循环）
# ARIA_REACT_MAX_STEPS=20

# 默认工作区模式：
# - aria: 通用 ARIA（唯一模式）
# ARIA_DEFAULT_WORKSPACE_MODE=aria

# --- 可选：真实浏览器自动化（Playwright）---
# 设为 1 且 pip install playwright && playwright install chromium 后，browser_open 用受控 Chromium；
# browser_click / browser_type 使用 CSS 选择器真实操作；未安装包时 browser_open 仍回退系统默认浏览器。
# ARIA_PLAYWRIGHT=1
# 无头模式（默认可见窗口）
# ARIA_PLAYWRIGHT_HEADLESS=1

# --- 可选：实验性桌面快捷键/输入（Windows + pywinauto）---
# ARIA_DESKTOP_UIA=1

# --- 可选：消息通道自动化（当前适配 wechat/wecom）---
# 设为 0 时关闭关键词启发式，仅用 LLM 规划 messaging_* 动作（见 automation/app_profiles/wechat_triggers.yaml）
# ARIA_MESSAGING_HEURISTIC=1
# 优先使用桌面客户端路径（更稳定）；桌面失败时默认不回退网页版（不自动打开浏览器）
# ARIA_WECHAT_PREFER_DESKTOP=1
# 设为 1 时：桌面失败才尝试网页版微信
# ARIA_WECHAT_WEB_FALLBACK=0
# 前台检测仍失败但需强行发键时（慎用）
# ARIA_WECHAT_RELAX_FOCUS_CHECK=0
# 微信发送快捷键：默认 Enter 发送；若你在微信里设为 Ctrl+Enter 发送则改为 ctrl_enter
# ARIA_WECHAT_SEND_HOTKEY=enter
# 搜索选中联系人后是否再按 Esc（默认不按；旧版可设 1）
# ARIA_WECHAT_SEND_ESC_AFTER_SEARCH=0
# 输入前是否 Esc（默认关：Esc 易收起会话像关窗）；字进搜索框时可试 1
# ARIA_WECHAT_ESC_BEFORE_TYPE=0
# 是否为企业微信（默认 false，设为 true 时操作企业微信）
# ARIA_ENTERPRISE_WECHAT=0
# 动作后自动截图（便于验证发送结果）
# ARIA_WECHAT_ACTION_SCREENSHOT=1

# --- 若改用阿里云百炼：修改 base_url 并改用下方密钥 ---
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_API_KEY=

# --- OCR 后端 ---
# tesseract（默认）| deepseek_local（本地 DeepSeek-OCR-2，需 CUDA）| deepseek_vlm（远程 VLM API）
# ARIA_OCR_BACKEND=tesseract
# 本地 DeepSeek-OCR-2 模型路径（留空则使用项目内 DeepSeek-OCR-2-main 目录；也可填 HuggingFace hub ID）
# DEEPSEEK_OCR2_MODEL_PATH=

# --- Computer Use（屏幕坐标级 GUI，对标 Claude Computer Use）---
# ARIA_COMPUTER_USE=0
# ARIA_COMPUTER_USE_ALLOW_REGIONS=[[0,0,800,600]]
# ARIA_COMPUTER_USE_BLOCK_TITLE_KEYWORDS=password,payment,银行
# ReAct 每步附带桌面 JPEG 给多模态模型（需 vision 模型；也可请求体 react_computer_use_vision）
# ARIA_REACT_COMPUTER_USE_VISION=1
# ARIA_REACT_COMPUTER_USE_JPEG_MAX=1280
# JPEG 质量 30–95，略降可减体积与编码耗时（默认 68）
# ARIA_REACT_COMPUTER_USE_JPEG_QUALITY=68

# --- 屏幕 OCR 后端 ---
# tesseract（默认）| deepseek_local（本地 DeepSeek-OCR-2，需 CUDA）| deepseek_vlm（远程 VLM API）
# deepseek_local / deepseek_vlm 不可用时自动降级到 tesseract
# ARIA_OCR_BACKEND=tesseract
# 本地 DeepSeek-OCR-2 模型路径（留空则使用项目内 DeepSeek-OCR-2-main 目录）
# DEEPSEEK_OCR2_MODEL_PATH=

# TAOR 自主循环（ARIA_TAOR_MODE=1）：默认拦截需确认/中高风险动作；受控环境可放行
# ARIA_TAOR_ALLOW_GATED_ACTIONS=0
# ARIA_TAOR_MAX_TURNS=20

# 权限谱：plan（只读探测）| default | accept_edits | dont_ask | bypass
# ARIA_PERMISSION_LEVEL=default

# --- 性能 / 体验（吞吐优先时推荐）---
# 推理：非复杂任务可将 REASONING_EFFORT_DEFAULT=low 或 minimal；关 ENABLE_THINKING 可再降延迟（百炼路径）
# 超时：LLM_TIMEOUT_SECONDS=30~45（网络差时勿过低）
# ReAct：ARIA_REACT_MAX_STEPS=8~12；仅必要时开 ARIA_REACT_COMPUTER_USE_VISION，JPEG 边长 960~1280
# 动作后截屏：生产关 ARIA_ACTION_SCREENSHOT 与前端「动作后截屏」
# 日志动画 sleep（默认 0）：演示时可设 300~500
# ARIA_UI_ANIMATION_SLEEP_MS=0
# LLM 重试：默认可重试 2 次；仅超时/5xx/429 等可重试；退避基数 500ms、上限 4s
# ARIA_LLM_MAX_RETRIES=2
# ARIA_LLM_RETRY_SLEEP_BASE_MS=500
# ARIA_LLM_RETRY_SLEEP_MAX_MS=4000

# --- KAIROS 主动执行引擎 ---
# 启用后台守护线程，协调定时触发（TriggerScheduler）和 AutoDream 记忆整合
# ARIA_KAIROS_ENABLED=1

# --- AutoDream 后台记忆整合 ---
# 系统空闲超过此秒数后触发一次 Dream 周期（默认 300s = 5分钟）
# ARIA_AUTODREAM_IDLE_SECONDS=300
# 两次 Dream 之间的最小间隔（默认 3600s = 1小时）
# ARIA_AUTODREAM_INTERVAL_SECONDS=3600